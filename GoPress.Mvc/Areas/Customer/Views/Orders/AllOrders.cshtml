@model List<GoPress.Mvc.Areas.Customer.Models.OrderViewModel>
@{
    ViewData["Title"] = "All Orders";
    Layout = "_Layout";
}
@section Styles
{
    <link rel="stylesheet"
          href="~/css/customer-orders.css"
          asp-append-version="true" />
}

<div class="orders-page">

    <div class="page-header">

        <div>

            <h2>My Orders</h2>

            <p>
                Track every laundry order from one place.
            </p>

        </div>

        <a asp-area="Customer"
           asp-controller="Orders"
           asp-action="Create"
           class="btn btn-primary">

            <i class="fa-solid fa-plus"></i>
            New Order

        </a>

    </div>
    @if (!Model.Any())
    {
        <div class="empty-box">

            <i class="fa-solid fa-box-open"></i>

            <h4>No Orders Found</h4>

            <p>You haven't placed any orders yet.</p>

        </div>
    }
    else
    {
        <div class="orders-grid">

            @foreach (var order in Model)
            {
                <div class="order-card">

                    <div class="order-card-header">

                        <div>

                            <h5>Order #@order.Id</h5>

                            <small>
                                Pickup :
                                @order.PickupDate.ToString("dd MMM yyyy")
                            </small>

                        </div>

                        <span class="status-badge status-@order.Status">
                            @order.Status
                        </span>

                    </div>

                    <div class="order-details">

                        <div class="detail-item">

                            <span>Pickup Date</span>

                            <strong>
                                @order.PickupDate.ToString("dd MMM yyyy")
                            </strong>

                        </div>

                        <div class="detail-item">

                            <span>Delivery Date</span>

                            <strong>
                                @(order.DeliveryDate?.ToString("dd MMM yyyy") ?? "-")
                            </strong>

                        </div>

                        <div class="detail-item">

                            <span>Total Amount</span>

                            <strong class="price">

                                ₹@order.TotalAmount

                            </strong>

                        </div>

                    </div>

                    <div class="clothes-section">

                        <h6>Clothes</h6>

                        <ul>

                            @foreach (var item in order.OrderItems)
                            {
                                <li>

                                    <span>@item.ClothName</span>

                                    <span>

                                        x @item.Quantity

                                    </span>

                                    <strong>

                                        ₹@item.TotalPrice

                                    </strong>

                                </li>
                            }

                        </ul>

                    </div>

                    <div class="card-footer">

                        <a asp-action="Details"
                           asp-route-id="@order.Id"
                           class="btn btn-primary">

                            View Details

                        </a>

                    </div>

                </div>
            }

        </div>
    }

</div>