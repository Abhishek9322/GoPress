@model List<GoPress.Mvc.Areas.Customer.Models.OrderViewModel>
@{
    ViewData["Title"] = "All Orders";
    Layout = "_Layout";
}

<div class="orders-page">

    <div class="page-header">

        <div>

            <h2>My Orders</h2>

            <p>
                Track every laundry order from one place.
            </p>

        </div>

        <a asp-area="Customer"
           asp-controller="Orders"
           asp-action="Create"
           class="btn btn-primary">

            <i class="fa-solid fa-plus"></i>
            New Order

        </a>

    </div>

    @if (!Model.Any())
    {
        <div class="empty-box">

            <i class="fa-solid fa-box-open"></i>

            <h4>No Orders Found</h4>

            <p>
                You haven't placed any orders yet.
            </p>

        </div>
    }
    else
    {

        <div class="table-responsive">

            <table class="table orders-table">

                <thead>

                    <tr>

                        <th>#</th>

                        <th>Pickup</th>

                        <th>Delivery</th>

                        <th>Pickup Date</th>

                        <th>Delivery Date</th>

                        <th>Amount</th>

                        <th>Status</th>

                        <th></th>

                    </tr>

                </thead>

                <tbody>

                    @foreach (var order in Model)
                    {
                        <tr>

                            <td>
                                #@order.Id
                            </td>

                            <td>
                                @order.PickupDate.ToString("dd MMM yyyy")
                            </td>

                            <td>
                                @(order.DeliveryDate?.ToString("dd MMM yyyy") ?? "-")
                            </td>

                            <td>
                                @order.PickupDate
                            </td>

                            <td>
                                @order.DeliveryDate
                            </td>

                            <td>

                                ₹@order.TotalAmount

                            </td>

                            <td>

                                @{
                                    var badgeClass = order.Status switch
                                    {
                                        "Pending" => "badge bg-warning text-dark",

                                        "Accepted" => "badge bg-primary",

                                        "Processing" => "badge bg-info",

                                        "OutForDelivery" => "badge bg-secondary",

                                        "Delivered" => "badge bg-success",

                                        "Rejected" => "badge bg-danger",

                                        "Cancelled" => "badge bg-dark",

                                        _ => "badge bg-light text-dark"
                                    };
                                }

                                <span class="@badgeClass">
                                    @order.Status
                                </span>

                            </td>

                            <td>

                                <a asp-action="Details"
                                   asp-route-id="@order.Id"
                                   class="btn btn-sm btn-outline-primary">

                                    View

                                </a>

                            </td>

                        </tr>

                        <tr>

                            <td colspan="8">

                                <div class="items-box">

                                    <strong>Clothes</strong>

                                    <ul>

                                        @foreach (var item in order.OrderItems)
                                        {
                                            <li>

                                                @item.ClothName

                                                ×

                                                @item.Quantity

                                                -

                                                ₹@item.TotalPrice

                                            </li>
                                        }

                                    </ul>

                                </div>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    }

</div>