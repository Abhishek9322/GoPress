@model GoPress.Mvc.Models.Auth.RegisterDeliveryBoyViewModel

@{
    ViewData["Title"] = "Delivery Partner Registration";
    Layout = "_Layout";
}

<style>

    body {
        background: #f5f7fb;
        font-family: 'Segoe UI';
    }

    .delivery-wrapper {
        padding: 50px 70px;
    }

    .top-heading {
        margin-bottom: 35px;
    }

        .top-heading span {
            background: #eafcff;
            color: #26c6da;
            padding: 8px 14px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
        }

        .top-heading h1 {
            margin-top: 20px;
            font-size: 52px;
            font-weight: bold;
        }

        .top-heading p {
            color: #666;
            font-size: 18px;
            width: 650px;
        }

    .delivery-container {
        display: flex;
        gap: 35px;
        align-items: flex-start;
    }

    /* LEFT FORM */

    .form-section {
        flex: 2;
        background: white;
        border-radius: 20px;
        padding: 40px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
    }

        .form-section h2 {
            font-size: 34px;
            font-weight: bold;
            margin-bottom: 8px;
        }

        .form-section small {
            color: #888;
        }

    .section-title {
        margin-top: 35px;
        margin-bottom: 20px;
        font-size: 18px;
        font-weight: 700;
        color: #333;
        border-bottom: 1px solid #eee;
        padding-bottom: 10px;
    }

    .form-label {
        font-weight: 600;
        margin-bottom: 8px;
    }

    .form-control {
        height: 55px;
        border-radius: 12px;
        border: 1px solid #ddd;
    }

    .submit-btn {
        width: 100%;
        margin-top: 30px;
        height: 60px;
        border: none;
        border-radius: 14px;
        background: #26c6da;
        color: white;
        font-size: 20px;
        font-weight: 600;
    }

        .submit-btn:hover {
            background: #13b3c8;
        }

    .terms {
        margin-top: 25px;
        color: #666;
        font-size: 14px;
    }

    /* RIGHT SIDE */

    .right-section {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 25px;
    }

    .info-card {
        background: white;
        border-radius: 18px;
        padding: 30px;
        box-shadow: 0 3px 15px rgba(0,0,0,0.08);
    }

        .info-card h3 {
            margin-bottom: 25px;
            font-size: 28px;
            font-weight: bold;
        }

    .benefit {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
    }

    .benefit-icon {
        width: 50px;
        height: 50px;
        background: #eafcff;
        border-radius: 14px;
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 22px;
    }

    .benefit-text h5 {
        margin-bottom: 5px;
        font-size: 18px;
        font-weight: 600;
    }

    .benefit-text p {
        color: #666;
        margin: 0;
        font-size: 14px;
    }

    .steps-card {
        background: #f7fff9;
        border: 2px dashed #bdecc8;
    }

    .step {
        display: flex;
        gap: 15px;
        margin-bottom: 20px;
        align-items: center;
    }

    .step-number {
        width: 35px;
        height: 35px;
        background: #22c55e;
        color: white;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: bold;
    }

    @@media(max-width: 992px) {

        .delivery-container {
            flex-direction: column;
        }

        .top-heading p {
            width: 100%;
        }

        .delivery-wrapper {
            padding: 30px;
        }
    }

</style>

<div class="delivery-wrapper">

    <!-- TOP -->

    <div class="top-heading">

        <span>
            Join The Fleet
        </span>

        <h1>
            Become a Delivery Partner
        </h1>

        <p>
            Ready to earn on your own schedule?
            Fill out the form below to start
            your delivery partner application.
        </p>

    </div>

    <div class="delivery-container">

        <!-- LEFT SIDE -->

        <div class="form-section">

            <h2>
                Application Form
            </h2>

            <small>
                Estimated completion time: 5 minutes
            </small>

            <form method="post">

                <!-- PERSONAL -->

                <div class="section-title">
                    Personal Information
                </div>

                <div class="row">

                    <div class="col-md-6 mb-4">

                        <label class="form-label">
                            Full Name
                        </label>

                        <input asp-for="FullName"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-4">

                        <label class="form-label">
                            Phone Number
                        </label>

                        <input asp-for="PhoneNumber"
                               class="form-control" />

                    </div>

                    <div class="col-md-12 mb-4">

                        <label class="form-label">
                            Email Address
                        </label>

                        <input asp-for="Email"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-4">

                        <label class="form-label">
                            Password
                        </label>

                        <input asp-for="Password"
                               type="password"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-4">

                        <label class="form-label">
                            Aadhaar Number
                        </label>

                        <input asp-for="AadhaarNumber"
                               class="form-control" />

                    </div>

                </div>

                <!-- ADDRESS -->

                <div class="section-title">
                    Address Details
                </div>

                <div class="row">

                    <div class="col-md-12 mb-4">

                        <label class="form-label">
                            Address
                        </label>

                        <input asp-for="Address"
                               class="form-control" />

                    </div>

                    <div class="col-md-4 mb-4">

                        <label class="form-label">
                            City
                        </label>

                        <input asp-for="City"
                               class="form-control" />

                    </div>

                    <div class="col-md-4 mb-4">

                        <label class="form-label">
                            State
                        </label>

                        <input asp-for="State"
                               class="form-control" />

                    </div>

                    <div class="col-md-4 mb-4">

                        <label class="form-label">
                            Pincode
                        </label>

                        <input asp-for="Pincode"
                               class="form-control" />

                    </div>

                </div>

                <!-- VEHICLE -->

                <div class="section-title">
                    Vehicle Information
                </div>

                <div class="row">

                    <div class="col-md-6 mb-4">

                        <label class="form-label">
                            Bike Number
                        </label>

                        <input asp-for="BikeNumber"
                               class="form-control" />

                    </div>

                    <div class="col-md-6 mb-4">

                        <label class="form-label">
                            License Number
                        </label>

                        <input asp-for="LicenseNumber"
                               class="form-control" />

                    </div>

                </div>

                <div class="terms">

                    <input type="checkbox" />

                    I agree to the
                    <a href="#">Terms of Service</a>
                    and
                    <a href="#">Partner Agreement</a>

                </div>

                <button type="submit"
                        class="submit-btn">

                    Apply as Delivery Partner

                </button>

            </form>

        </div>

        <!-- RIGHT SIDE -->

        <div class="right-section">

            <!-- BENEFITS -->

            <div class="info-card">

                <h3>
                    Why join Press & Go?
                </h3>

                <div class="benefit">

                    <div class="benefit-icon">
                        💰
                    </div>

                    <div class="benefit-text">

                        <h5>
                            Weekly Payouts
                        </h5>

                        <p>
                            Receive your earnings directly
                            into your bank account.
                        </p>

                    </div>

                </div>

                <div class="benefit">

                    <div class="benefit-icon">
                        ⏰
                    </div>

                    <div class="benefit-text">

                        <h5>
                            Flexible Hours
                        </h5>

                        <p>
                            Work whenever you want
                            on your own schedule.
                        </p>

                    </div>

                </div>

                <div class="benefit">

                    <div class="benefit-icon">
                        🛡️
                    </div>

                    <div class="benefit-text">

                        <h5>
                            Partner Support
                        </h5>

                        <p>
                            Dedicated support team
                            available for all riders.
                        </p>

                    </div>

                </div>

            </div>

            <!-- STEPS -->

            <div class="info-card steps-card">

                <h3>
                    What happens next?
                </h3>

                <div class="step">

                    <div class="step-number">
                        1
                    </div>

                    <div>
                        Submit your application
                    </div>

                </div>

                <div class="step">

                    <div class="step-number">
                        2
                    </div>

                    <div>
                        Verification process
                    </div>

                </div>

                <div class="step">

                    <div class="step-number">
                        3
                    </div>

                    <div>
                        Complete onboarding
                    </div>

                </div>

                <div class="step">

                    <div class="step-number">
                        4
                    </div>

                    <div>
                        Start earning deliveries
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>