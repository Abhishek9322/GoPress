@model GoPress.Mvc.Models.Auth.RegisterCustomerViewModel

@{
    ViewData["Title"] = "Customer Registration";
}

<style>

    body {
        background: #f5f7fb;
        font-family: 'Segoe UI', sans-serif;
    }

    .register-wrapper {
        padding: 60px 0;
    }

    .register-card {
        width: 100%;
        max-width: 620px;
        margin: auto;
        background: white;
        border-radius: 22px;
        padding: 45px;
        box-shadow: 0 5px 25px rgba(0,0,0,0.08);
    }

    .top-icon {
        width: 70px;
        height: 70px;
        background: #e9fbff;
        color: #20c7e6;
        border-radius: 50%;
        margin: auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 28px;
        margin-bottom: 20px;
    }

    .register-title {
        text-align: center;
        font-size: 42px;
        font-weight: 700;
        color: #111827;
    }

    .register-subtitle {
        text-align: center;
        color: #6b7280;
        margin-top: 10px;
        margin-bottom: 40px;
        line-height: 1.7;
    }

    .section-title {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 2px;
        color: #6b7280;
        margin-bottom: 20px;
        border-bottom: 1px solid #e5e7eb;
        padding-bottom: 10px;
    }

    .form-label {
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
    }

    .form-control {
        height: 52px;
        border-radius: 12px;
        border: 1px solid #d1d5db;
        padding-left: 16px;
        box-shadow: none !important;
    }

    textarea.form-control {
        height: 110px;
        padding-top: 15px;
    }

    .form-control:focus {
        border-color: #20c7e6;
    }

    .register-btn {
        width: 100%;
        height: 56px;
        border: none;
        border-radius: 14px;
        background: #20c7e6;
        color: white;
        font-size: 18px;
        font-weight: 600;
        margin-top: 25px;
        transition: 0.3s;
    }

        .register-btn:hover {
            background: #0ea5c6;
        }

    .login-link {
        text-align: center;
        margin-top: 25px;
        color: #6b7280;
    }

        .login-link a {
            text-decoration: none;
            color: #20c7e6;
            font-weight: 600;
        }

    .extra-box {
        max-width: 620px;
        margin: 25px auto 0;
        background: white;
        border: 1px dashed #d1d5db;
        border-radius: 16px;
        padding: 25px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .extra-buttons a {
        text-decoration: none;
        border: 1px solid #d1d5db;
        padding: 10px 18px;
        border-radius: 10px;
        margin-left: 10px;
        color: #111827;
        font-weight: 600;
        transition: 0.3s;
    }

        .extra-buttons a:hover {
            background: #20c7e6;
            color: white;
            border-color: #20c7e6;
        }

</style>

<div class="container register-wrapper">

    <div class="register-card">

        <div class="top-icon">
            👤
        </div>

        <h1 class="register-title">
            Join Press & Go
        </h1>

        <p class="register-subtitle">
            Create your customer account to start your first
            order and enjoy professional garment care.
        </p>

        <form method="post">

            <!-- PERSONAL INFO -->

            <div class="section-title">
                PERSONAL INFORMATION
            </div>

            <div class="row">

                <div class="col-md-12 mb-4">

                    <label class="form-label">
                        Full Name
                    </label>

                    <input asp-for="FullName"
                           class="form-control"
                           placeholder="John Doe" />

                </div>

                <div class="col-md-6 mb-4">

                    <label class="form-label">
                        Email Address
                    </label>

                    <input asp-for="Email"
                           class="form-control"
                           placeholder="john@example.com" />

                </div>

                <div class="col-md-6 mb-4">

                    <label class="form-label">
                        Phone Number
                    </label>

                    <input asp-for="PhoneNumber"
                           class="form-control"
                           placeholder="+91 9876543210" />

                </div>

                <div class="col-md-6 mb-4">

                    <label class="form-label">
                        Password
                    </label>

                    <input asp-for="Password"
                           type="password"
                           class="form-control"
                           placeholder="********" />

                </div>

                <div class="col-md-6 mb-4">

                    <label class="form-label">
                        Confirm Password
                    </label>

                    <input type="password"
                           class="form-control"
                           placeholder="********" />

                </div>

            </div>

            <!-- DELIVERY -->

            <div class="section-title mt-4">
                LOGISTICS & DELIVERY
            </div>

            <div class="mb-4">

                <label class="form-label">
                    Pickup Address
                </label>

                <textarea asp-for="Address"
                          class="form-control"
                          placeholder="Enter your full street address, apartment number, and city..."></textarea>

            </div>

            <div class="row">

                <div class="col-md-4 mb-4">

                    <label class="form-label">
                        City
                    </label>

                    <input asp-for="City"
                           class="form-control"
                           placeholder="Mumbai" />

                </div>

                <div class="col-md-4 mb-4">

                    <label class="form-label">
                        State
                    </label>

                    <input asp-for="State"
                           class="form-control"
                           placeholder="Maharashtra" />

                </div>

                <div class="col-md-4 mb-4">

                    <label class="form-label">
                        Pincode
                    </label>

                    <input asp-for="Pincode"
                           class="form-control"
                           placeholder="400001" />

                </div>

            </div>

            <div class="mb-4">

                <label class="form-label">
                    Optional Delivery Notes
                </label>

                <input type="text"
                       class="form-control"
                       placeholder="e.g., Gate code 1234, leave at side door" />

            </div>

            <div class="form-check mt-4">

                <input class="form-check-input"
                       type="checkbox"
                       id="termsCheck" />

                <label class="form-check-label"
                       for="termsCheck">

                    Accept terms and conditions

                </label>

            </div>

            <button type="submit"
                    class="register-btn">

                Create Account →

            </button>

            <div class="login-link">

                Already have an account?

                <a asp-controller="Auth"
                   asp-action="Login">

                    Sign In

                </a>

            </div>

        </form>

    </div>

    <!-- EXTRA BOX -->

    <div class="extra-box">

        <div>

            <strong>
                Not a customer?
            </strong>

            <div class="text-muted">
                Register your shop or join as a delivery partner.
            </div>

        </div>

        <div class="extra-buttons">

            <a asp-controller="Auth"
               asp-action="RegisterShopOwner">

                Shop Owner

            </a>

            <a asp-controller="Auth"
               asp-action="RegisterDeliveryBoy">

                Delivery Boy

            </a>

        </div>

    </div>

</div>