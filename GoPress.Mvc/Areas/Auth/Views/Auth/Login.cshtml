@model GoPress.Mvc.Models.Auth.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="login-wrapper">

    <div class="login-container">

        <!-- Logo -->

        <div class="logo-box">

            <div class="logo-icon">
                <i class="fa-solid fa-shirt"></i>
            </div>

            <div class="brand-name">
                Press & Go
            </div>

        </div>

        <!-- Login Card -->

        <div class="login-card">

            <h1 class="login-title">
                Welcome Back
            </h1>

            <p class="login-subtitle">
                Enter your email and password to access your account.
            </p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger mb-3">
                    @ViewBag.Error
                </div>
            }

            <form asp-action="Login"
                  asp-controller="Auth"
                  asp-area="Auth"
                  method="post">

                <!-- Email -->

                <div class="mb-3">

                    <label asp-for="Email"
                           class="form-label">
                    </label>

                    <input asp-for="Email"
                           class="form-control"
                           placeholder="name@example.com" />

                    <span asp-validation-for="Email"
                          class="text-danger">
                    </span>

                </div>

                <!-- Password -->

                <div class="password-row">

                    <label asp-for="Password"
                           class="form-label">
                    </label>

                    <a href="#"
                       class="forgot-link">

                        Forgot Password?

                    </a>

                </div>

                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       placeholder="Enter Password" />

                <span asp-validation-for="Password"
                      class="text-danger">
                </span>

                <!-- Remember -->

                <div class="remember-box">

                    <input type="checkbox"
                           id="remember" />

                    <label for="remember">
                        Remember me for 30 days
                    </label>

                </div>

                <!-- Login Button -->

                <button type="submit"
                        class="login-btn">

                    Sign In

                </button>

            </form>

            <!-- Register -->

            <div class="register-box">

                Don't have an account?

                <a asp-area="Auth"
                   asp-controller="Auth"
                   asp-action="RegisterCustomer">

                    Register Now

                </a>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}