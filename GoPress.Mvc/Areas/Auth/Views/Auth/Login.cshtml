@using GoPress.Mvc.Areas.Auth.Auth
@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout";
}

<div class="container">

    <div class="login-wrapper">

        <div class="login-container">

            <div class="logo-box">

                <div class="logo-icon">
                    <i class="fa-solid fa-shirt"></i>
                </div>

                <div class="brand-name">
                    Press & Go
                </div>

            </div>

            <div class="login-card">

                <h2 class="login-title">
                    Welcome Back
                </h2>

                <p class="login-subtitle">
                    Sign in to continue using Press & Go.
                </p>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                <form asp-area="Auth"
                      asp-controller="Auth"
                      asp-action="Login"
                      method="post">

                    <div class="mb-3">
                        <label class="form-label">Email</label>

                        <input type="email"
                               id="Email"
                               name="Email"
                               class="form-control"
                               placeholder="Enter Email Address"
                               value="@Model?.Email" />
                    </div>

                    <div class="mb-3">

                        <div class="password-row">
                            <label class="form-label">Password</label>

                            <a href="#" class="forgot-link">
                                Forgot Password?
                            </a>
                        </div>

                        <input type="password"
                               id="Password"
                               name="Password"
                               class="form-control"
                               placeholder="Enter Password" />

                    </div>

                    <div class="remember-box">

                        <input type="checkbox"
                               id="rememberMe">

                        <label for="rememberMe">
                            Remember Me
                        </label>

                    </div>

                    <button type="submit"
                            class="login-btn">
                        Login
                    </button>

                </form>

                <div class="register-box">

                    Don't have an account?

                    <a asp-area="Auth"
                       asp-controller="Auth"
                       asp-action="RegisterCustomer">

                        Create Account

                    </a>

                </div>

            </div>

        </div>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}