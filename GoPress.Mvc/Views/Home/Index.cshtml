@{
    ViewData["Title"] = "Home";
}

<!-- NAVBAR -->

<nav class="custom-navbar">

    <div class="logo">
        Press & Go
    </div>

    <div class="nav-links">

        <a href="#">Home</a>

        <a href="#">Services</a>

        <a href="#">Locations</a>

        <a href="#">How It Works</a>

    </div>

    <div class="nav-links">

        <a asp-controller="Auth"
           asp-action="Login"
           class="signin-btn">

            Sign In

        </a>

        <a asp-controller="Auth"
           asp-action="Login"
           class="start-btn">

            Get Started

        </a>

    </div>

</nav>

<!-- HERO -->

<section class="hero-section">

    <div class="hero-card">

        <h1>
            Crisp Clothes,
            Delivered Daily
        </h1>

        <p>
            Professional pressing services
            at your doorstep.
            Schedule your first pickup today.
        </p>

        <div class="hero-buttons">

            <a href="#"
               class="order-btn">

                Order Now

            </a>

            <a href="#"
               class="learn-btn">

                Learn More

            </a>

        </div>

    </div>

</section>

<!-- FEATURES -->

<section class="features">

    <div class="feature-card blue-bg">

        <h3>Express Delivery</h3>

        <p>
            24-hour turnaround for all laundry items.
        </p>

    </div>

    <div class="feature-card green-bg">

        <h3>Premium Care</h3>

        <p>
            Specialized pressing for delicate garments.
        </p>

    </div>

    <div class="feature-card yellow-bg">

        <h3>Bulk Discounts</h3>

        <p>
            Save more with family and business plans.
        </p>

    </div>

</section>

<!-- PROCESS -->

<section class="process-section">

    <div class="section-title">

        <h2>
            How Press & Go Works
        </h2>

        <p>
            Easy pickup and delivery process.
        </p>

    </div>

    <div class="steps">

        <div class="step-card">

            <div class="step-number">1</div>

            <h4>Schedule Pickup</h4>

            <p>Select a pickup time.</p>

        </div>

        <div class="step-card">

            <div class="step-number">2</div>

            <h4>Collection</h4>

            <p>Delivery partner collects clothes.</p>

        </div>

        <div class="step-card">

            <div class="step-number">3</div>

            <h4>Pressing</h4>

            <p>Professional garment care.</p>

        </div>

        <div class="step-card">

            <div class="step-number">4</div>

            <h4>Delivery</h4>

            <p>Fresh clothes delivered.</p>

        </div>

    </div>

</section>

<!-- JOIN SECTION -->

<section class="cta-section">

    <div class="cta-cards">

        <!-- CUSTOMER -->

        <div class="cta-card">

            <img src="https://images.unsplash.com/photo-1520607162513-77705c0f0d4a" />

            <div class="cta-content">

                <h3>Customer</h3>

                <ul>
                    <li>Fast Pickup</li>
                    <li>Live Tracking</li>
                    <li>Quick Delivery</li>
                </ul>

                <a asp-controller="Auth"
                   asp-action="RegisterCustomer"
                   class="register-btn customer-btn">

                    Register as Customer

                </a>

            </div>

        </div>

        <!-- SHOP OWNER -->

        <div class="cta-card">

            <img src="https://images.unsplash.com/photo-1517677208171-0bc6725a3e60" />
         
            <div class="cta-content">

                <h3>Shop Owner</h3>

                <ul>
                    <li>More Customers</li>
                    <li>Manage Orders</li>
                    <li>Business Dashboard</li>
                </ul>

                <a asp-controller="Auth"
                   asp-action="RegisterShopOwner"
                   class="register-btn shop-btn">

                    Register as Shop Owner

                </a>

            </div>

        </div>

        <!-- DELIVERY -->

        <div class="cta-card">

            <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb" />

            <div class="cta-content">

                <h3>Delivery Boy</h3>

                <ul>
                    <li>Flexible Hours</li>
                    <li>Daily Earnings</li>
                    <li>Simple Workflow</li>
                </ul>

                <a asp-controller="Auth"
                   asp-action="RegisterDeliveryBoy"
                   class="register-btn delivery-btn">

                    Join as Delivery Boy

                </a>

            </div>

        </div>

    </div>

</section>

<!-- FOOTER -->

<footer>

    <div class="footer-grid">

        <div class="footer-column">

            <h4>Press & Go</h4>

            <p>
                Professional laundry delivery service.
            </p>

        </div>

        <div class="footer-column">

            <h4>Company</h4>

            <a href="#">About</a>

            <a href="#">Careers</a>

            <a href="#">Contact</a>

        </div>

        <div class="footer-column">

            <h4>Support</h4>

            <a href="#">Help Center</a>

            <a href="#">Privacy Policy</a>

        </div>

    </div>

</footer>