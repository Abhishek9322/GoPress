@{
    ViewData["Title"] = "Home";
}

<!-- HERO SECTION -->

<section class="hero-section">

    <div class="container">

        <div class="hero-card">

            <h1>
                Crisp Clothes,
                Delivered Daily
            </h1>

            <p>
                Professional pressing services at your doorstep.
                Schedule your first pickup today.
            </p>

            <div class="hero-buttons">

                <a href="#" class="order-btn">
                    Order Now
                </a>

                <a href="#" class="learn-btn">
                    Learn More
                </a>

            </div>

        </div>

    </div>

</section>

<!-- FEATURES -->

<section class="features">

    <div class="container">

        <div class="feature-wrapper">

            <div class="feature-card blue-bg">

                <h3>Express Delivery</h3>

                <p>
                    24-hour turnaround for all laundry items.
                </p>

            </div>

            <div class="feature-card green-bg">

                <h3>Premium Care</h3>

                <p>
                    Specialized pressing for delicate garments.
                </p>

            </div>

            <div class="feature-card yellow-bg">

                <h3>Bulk Discounts</h3>

                <p>
                    Save more with family and business plans.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- HOW IT WORKS -->

<section class="process-section">

    <div class="container">

        <div class="section-title">

            <h2>
                How Press & Go Works
            </h2>

            <p>
                Easy pickup and delivery process.
            </p>

        </div>

        <div class="steps">

            <div class="step-card">

                <div class="step-number">
                    1
                </div>

                <h4>
                    Schedule Pickup
                </h4>

                <p>
                    Select a pickup time.
                </p>

            </div>

            <div class="step-card">

                <div class="step-number">
                    2
                </div>

                <h4>
                    Collection
                </h4>

                <p>
                    Delivery partner collects your clothes.
                </p>

            </div>

            <div class="step-card">

                <div class="step-number">
                    3
                </div>

                <h4>
                    Professional Pressing
                </h4>

                <p>
                    Expert garment care and ironing.
                </p>

            </div>

            <div class="step-card">

                <div class="step-number">
                    4
                </div>

                <h4>
                    Home Delivery
                </h4>

                <p>
                    Fresh clothes delivered back to your doorstep.
                </p>

            </div>

        </div>

    </div>

</section>

<!-- JOIN PRESS & GO -->

<section class="cta-section">

    <div class="container">

        <div class="cta-cards">

            <!-- CUSTOMER -->

            <div class="cta-card">

                <img src="https://images.unsplash.com/photo-1520607162513-77705c0f0d4a"
                     alt="Customer" />

                <div class="cta-content">

                    <h3>
                        Customer
                    </h3>

                    <ul>

                        <li>Fast Pickup</li>

                        <li>Live Order Tracking</li>

                        <li>Doorstep Delivery</li>

                    </ul>

                    <a asp-area="Auth"
                       asp-controller="Auth"
                       asp-action="RegisterCustomer"
                       class="register-btn customer-btn">

                        Register as Customer

                    </a>

                </div>

            </div>

            <!-- SHOP OWNER -->

            <div class="cta-card">

                <img src="https://images.unsplash.com/photo-1517677208171-0bc6725a3e60"
                     alt="Shop Owner" />

                <div class="cta-content">

                    <h3>
                        Shop Owner
                    </h3>

                    <ul>

                        <li>Receive More Orders</li>

                        <li>Manage Customers</li>

                        <li>Business Dashboard</li>

                    </ul>

                    <a asp-area="Auth"
                       asp-controller="Auth"
                       asp-action="RegisterShopOwner"
                       class="register-btn shop-btn">

                        Register as Shop Owner

                    </a>

                </div>

            </div>

            <!-- DELIVERY BOY -->

            <div class="cta-card">

                <img src="https://images.unsplash.com/photo-1506744038136-46273834b3fb"
                     alt="Delivery Partner" />

                <div class="cta-content">

                    <h3>
                        Delivery Partner
                    </h3>

                    <ul>

                        <li>Flexible Working Hours</li>

                        <li>Daily Earnings</li>

                        <li>Simple Delivery Workflow</li>

                    </ul>

                    <a asp-area="Auth"
                       asp-controller="Auth"
                       asp-action="RegisterDeliveryBoy"
                       class="register-btn delivery-btn">

                        Join as Delivery Partner

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>